# Database
DATABASE_URL="postgresql://username:password@localhost:5432/nutryhome"

# JWT
JWT_SECRET="your-secret-key"

# ElevenLabs Batch Calling API
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
ELEVENLABS_BASE_URL="https://api.elevenlabs.io/v1"
ELEVENLABS_AGENT_ID="your-isabela-agent-id"
ELEVENLABS_PHONE_NUMBER_ID="your-phone-number-id"
ELEVENLABS_PROJECT_ID="your-project-id"

# Rate Limiting
ELEVENLABS_RATE_LIMIT_PER_MINUTE=60
ELEVENLABS_MAX_RETRIES=3

# Configuración del Servidor
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_EXPIRES_IN=24h

# ElevenLabs Webhook
ELEVENLABS_WEBHOOK_SECRET=your-elevenlabs-webhook-secret

# Builderbot pull secret — Builderbot manda este header (X-Builderbot-Secret)
# al endpoint GET /api/contacts/by-phone para hidratar variables del flow F0.
# Si está vacío, el endpoint acepta sin firma (modo desarrollo).
BUILDERBOT_PULL_SECRET=change-me-shared-with-builderbot-flow

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info 